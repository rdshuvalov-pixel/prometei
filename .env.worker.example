# URL проекта Supabase (как в Vercel NEXT_PUBLIC_SUPABASE_URL)
SUPABASE_URL=https://xxxx.supabase.co

# Сервисная роль — только на VPS, не в git
SUPABASE_SERVICE_ROLE_KEY=

# Интервал опроса очереди (сек)
POLL_INTERVAL_SEC=20

# Таймаут одной задачи (сек)
JOB_TIMEOUT_SEC=3600

# Команда на хосте внутри контейнера (shell). Пример, когда положишь код краулера в образ/том:
# WORKER_CMD=python3 /data/prometheus_agent/script_crawl.py
#
# Пока пусто — воркер помечает queued-задачи как done со stub в counters (чтобы очередь не зависала).
