# URL проекта Supabase (как в Vercel NEXT_PUBLIC_SUPABASE_URL)
SUPABASE_URL=https://xxxx.supabase.co

# Сервисная роль — только на VPS, не в git
SUPABASE_SERVICE_ROLE_KEY=

# Лимит URL за один прогон script_crawl: число >0 или 0 = без лимита (все URL из markdown)
# MAX_CRAWL_URLS=500
# MAX_CRAWL_URLS=0
# Пауза между HTTP-запросами (сек)
# CRAWL_DELAY_SEC=1

# Домены не качать (через запятую). По умолчанию в коде: weworkremotely.com
# CRAWL_SKIP_DOMAINS=weworkremotely.com

# Вакансии из JSON-LD JobPosting старше N дней по datePosted не вставлять (по умолчанию 5)
# LISTING_MAX_AGE_DAYS=5

# Переопределить целевой запрос Tier 4 (иначе из prometheus_agent/search_targets.md: _TIER4_QUERY / # QUERY:)
# TIER4_QUERY="Product Manager" OR "Product Lead" remote EU

# Интервал опроса очереди (сек)
POLL_INTERVAL_SEC=20

# После WORKER_CMD: парсить JSON из блока «--- сводка ---» в job_runs.counters (1=да)
# WORKER_PARSE_CHILD_COUNTERS=1

# Таймаут одной задачи (сек)
JOB_TIMEOUT_SEC=3600

# Команда внутри контейнера (shell). Префикс пути — только /app/ (WORKDIR в Dockerfile.worker), не /data/.
# Варианты:
# — только career crawl + отчёт в prometheus_agent/out/
# WORKER_CMD=python3 /app/prometheus_agent/script_crawl.py
# — диспетчер: по JOB_TYPE из очереди → script_crawl или Ashby Tier4
# WORKER_CMD=python3 /app/prometheus_agent/worker_dispatch.py
#
# Воркер передаёт в процесс: JOB_ID, WORKER_JOB_ID, JOB_TYPE.
# JOB_TYPE из веб/API:
#   script_crawl | tier4_ashby | tier4_board_feeds | keyword_search | full_search
#   vacancy_enrich | vacancy_score | vacancy_llm (опционально)

WORKER_CMD=python3 /app/prometheus_agent/worker_dispatch.py

# --- LLM (опционально) ---
# vacancy_llm читает OpenAI-compatible API. Для OpenRouter:
# OPENAI_BASE_URL="https://openrouter.ai/api/v1"
# OPENAI_MODEL="qwen/qwen3.5-flash"   # проверь slug модели в OpenRouter
# OPENAI_API_KEY="..."                # НЕ коммить
# LLM_MIN_SCORE=70
# VACANCY_LLM_BATCH=30

# --- Ashby Tier4 (если WORKER_CMD=worker_dispatch.py и job_type tier4_ashby) ---
# ASHBY_SLUGS=kraken.com,other.co
# TIER4_MAX_JOB_AGE_DAYS=5
# ASHBY_DELAY_SEC=0.65
# TIER4_RELAX_GEO=1

# --- Greenhouse + Lever + Workable (job_type tier4_board_feeds) ---
# Токен доски — сегмент из URL: job-boards.greenhouse.io/TOKEN/… или job-boards.eu.greenhouse.io/TOKEN/…
# (для JetBrains PM-ролей из EU-доски: добавь jetbrains, иначе в vacancies не попадёт)
# GREENHOUSE_BOARD_TOKENS=dwelly,jetbrains
# LEVER_COMPANIES=truv,appfollow
# WORKABLE_ACCOUNT_SLUGS=2070health
# WORKABLE_MAX_PAGES=20
# Публичные агрегаторы (по умолчанию включены; REMOTIVE_TIER4=0 / REMOTEOK_TIER4=0 — выкл.)
# REMOTIVE_TIER4=1
# REMOTEOK_TIER4=1
# BOARD_FEED_DELAY_SEC=0.55
